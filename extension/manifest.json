{
  "manifest_version": 3,
  "name": "StreamForge AI",
  "version": "1.0.0",
  "description": "YouTube video downloader powered by StreamForge AI backend",

  "permissions": [
  "activeTab",
  "scripting",
  "downloads",
  "storage",
  "tabs",
  "notifications"
],

  "host_permissions": [
    "https://www.youtube.com/*",
    "http://localhost:8080/*",
    "http://localhost:8001/*"
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "StreamForge AI"
  },

  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ],

  "background": {
    "service_worker": "background/background.js"
  }
}